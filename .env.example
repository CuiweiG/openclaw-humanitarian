# Telegram Bot Token (required for bot)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Anthropic API Key (optional, for AI translation)
# Leave empty to use stub/rule-based translation
ANTHROPIC_API_KEY=

# ReliefWeb API (no key needed, but set user agent)
RELIEFWEB_APP_NAME=openclaw-humanitarian

# Translation settings
DEFAULT_LANGUAGES=fa,dar,ar
MAX_BULLETIN_WORDS=200
